# clang-tidy configuration generated by Start Green Stay Green.
#
# Shared by scripts/lint.sh and the pre-commit clang-tidy hook. Both run
# with -p build, so build/compile_commands.json must exist (the cmake
# configure step exports it; CMAKE_EXPORT_COMPILE_COMMANDS is ON in the
# generated CMakeLists.txt).
#
# Security posture (documented, not implied): clang-analyzer-* runs the
# Clang Static Analyzer's path-sensitive checks inside clang-tidy, and
# cert-*/bugprone-* cover the CERT secure-coding patterns. Secret
# scanning is handled by the gitleaks and detect-secrets pre-commit
# hooks, dangerous-API scanning by flawfinder (scripts/security.sh).
#
# Complexity: the <=10 cyclomatic-complexity ceiling is enforced by
# lizard in scripts/lint.sh (single source of truth), not duplicated
# via readability-function-cognitive-complexity here.
#
# Tighten-me: enable cppcoreguidelines-* and misc-* once the codebase is
# ready for their stricter ownership/include rules.
---
Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  concurrency-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -readability-identifier-length,
  -readability-magic-numbers
# Promote every enabled check to an error so lint.sh and the pre-commit
# hook fail on findings instead of scrolling them past.
WarningsAsErrors: '*'
# Report findings in first-party headers too (clang-tidy only runs on
# .cpp translation units; this regex pulls inc/ and src/ headers into
# the diagnostics).
HeaderFilterRegex: '(inc|src)/'
