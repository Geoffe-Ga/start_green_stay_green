# clang-format configuration generated by Start Green Stay Green.
#
# Shared by scripts/format.sh and the pre-commit clang-format hook so
# there is exactly one source of formatting truth. Google style is the
# base; the overrides below are deliberate, documented choices.
---
BasedOnStyle: Google
# Matches the CMAKE_CXX_STANDARD pinned in CMakeLists.txt.
Standard: c++17
ColumnLimit: 100
IndentWidth: 4
DerivePointerAlignment: false
PointerAlignment: Left
